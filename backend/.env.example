# AutoDiag backend ortam değişkenleri (örnek). Kopyala: cp .env.example .env

# PostgreSQL + pgvector (üretim yolu). Demo modunda gerekmez (bellek-içi motor).
# DATABASE_URL=postgresql+psycopg://autodiag:autodiag@localhost:5432/autodiag

# LLM API anahtarı (Anthropic). Boşsa RAG katmanı extractive fallback'e düşer.
# LLM_API_KEY=sk-ant-...

# Embedding modeli:
#   (boş)      → base çok dilli MiniLM (paraphrase-multilingual-MiniLM-L12-v2)
#   adapted    → yerel domain-adapte model (models/autodiag-embed-tr)
#                argo/günlük sorgularda daha iyi; önce: python scripts/finetune_embedding.py
# EMBEDDING_MODEL=adapted
